---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

import heroAerial from '../assets/deck/hero-aerial.jpg';
import section2Bedroom from '../assets/deck/section2-bedroom.jpg';
import section3Garden from '../assets/deck/section3-garden.jpg';
import section5Bedroom from '../assets/deck/section5-sanctuary-bedroom.jpg';
import section5Dining from '../assets/deck/section5-sanctuary-dining.jpg';
import section6Landscape from '../assets/deck/section6-pnw-landscape.jpg';
import section8Sunset from '../assets/deck/section8-closing-sunset.jpg';

const description =
  'A new Pacific Northwest neighborhood is coming together. The peace and space people leave the city for. The walkability and culture they leave behind. We\'re building for both.';
---

<Layout title="Now City Neighborhoods" description={description}>
  {/* ============================================================ */}
  {/* SECTION 1 — HERO                                             */}
  {/* ============================================================ */}
  <section class="pt-12 md:pt-16 lg:pt-20">
    <div class="container-wide">
      <div class="overflow-hidden rounded-md shadow-sm">
        <Image
          src={heroAerial}
          alt="Aerial rendering of a green, low-rise neighborhood block with rooftop gardens and an interior courtyard."
          widths={[800, 1200, 1800, 2200]}
          sizes="(min-width: 1024px) 1100px, 100vw"
          class="h-auto w-full object-cover"
          loading="eager"
        />
      </div>
      <div class="mt-10 max-w-3xl md:mt-12">
        <h1 class="font-display text-display-xl text-forest-700">
          Neighborhoods Designed for Life.
        </h1>
        <p class="lede mt-6">
          A new Pacific Northwest neighborhood is coming together. The
          peace and space people leave the city for. The walkability
          and culture they leave behind. We're building for both. So
          you don't have to choose.
        </p>
        <p class="mt-10">
          <a href="#follow-along" class="btn-primary">
            Follow along
            <span aria-hidden="true">→</span>
          </a>
        </p>
      </div>
    </div>
  </section>

  {/* ============================================================ */}
  {/* SECTION 2 — A BETTER WAY TO LIVE                             */}
  {/* ============================================================ */}
  <section class="py-section mt-section">
    <div class="container-wide">
      <div class="grid gap-12 md:grid-cols-2 md:items-center md:gap-16">
        <div>
          <h2 class="font-display text-display-lg text-forest-700">
            A Better Way to Live.
          </h2>
          <p class="prose-body mt-8">
            Now City behaves like a thoughtful host. Places should be
            designed around people and everyday life, rather than vehicles
            or financial engineering. We create walkable neighborhood
            ecosystems where nature, culture, and community are integrated
            into daily routines.
          </p>
          <div class="mt-10 h-px w-16 bg-copper-400" aria-hidden="true"></div>
          <blockquote class="mt-8 font-display text-xl italic leading-relaxed text-forest-800 md:text-2xl">
            We are building environments that support everyday well-being
            and social connection. The result is a place people naturally
            want to be.
          </blockquote>
        </div>
        <div class="overflow-hidden rounded-md shadow-sm">
          <Image
            src={section2Bedroom}
            alt="A light-filled bedroom with timber ceiling, linen bedding, and a tree-framed window."
            widths={[600, 900, 1400]}
            sizes="(min-width: 768px) 50vw, 100vw"
            class="h-auto w-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  {/* ============================================================ */}
  {/* SECTION 3 — REGENERATIVE LIVING                              */}
  {/* ============================================================ */}
  <section class="py-section bg-cream-50">
    <div class="container-wide">
      <div class="max-w-3xl">
        <h2 class="font-display text-display-lg text-forest-700">
          Regenerative Living.
        </h2>
        <p class="lede mt-6">
          Regenerative is what makes a neighborhood feel good to live in,
          year after year. It works across five things you feel every day.
        </p>
      </div>

      <div class="mt-12 overflow-hidden rounded-md shadow-sm">
        <Image
          src={section3Garden}
          alt="A community garden with raised beds, residents tending vegetables, framed by neighborhood buildings on either side."
          widths={[1000, 1500, 2000]}
          sizes="(min-width: 1024px) 1100px, 100vw"
          class="h-auto w-full object-cover"
        />
      </div>

      <ol class="mt-16 grid gap-x-10 gap-y-12 md:grid-cols-2 lg:grid-cols-3">
        <li>
          <div class="h-px w-10 bg-copper-400" aria-hidden="true"></div>
          <p class="eyebrow mt-4">01 / Well-Being</p>
          <p class="prose-body mt-3">
            Biophilic streetscapes, shaded walking paths, green plazas,
            and active gathering spaces that support daily movement,
            mental health, and social connection.
          </p>
        </li>
        <li>
          <div class="h-px w-10 bg-copper-400" aria-hidden="true"></div>
          <p class="eyebrow mt-4">02 / Community</p>
          <p class="prose-body mt-3">
            A daily civic marketplace at the heart. Long tables, fire
            pits, a simple stage. Saying hello becomes the default.
          </p>
        </li>
        <li>
          <div class="h-px w-10 bg-copper-400" aria-hidden="true"></div>
          <p class="eyebrow mt-4">03 / Nature</p>
          <p class="prose-body mt-3">
            Landscape as living infrastructure: cooling, stormwater
            management, microclimate regulation, biodiversity. Designed
            with nature's logic, not tacked onto development.
          </p>
        </li>
        <li>
          <div class="h-px w-10 bg-copper-400" aria-hidden="true"></div>
          <p class="eyebrow mt-4">04 / Family</p>
          <p class="prose-body mt-3">
            Child-centered public realms with safe mobility, nature-based
            play, and everyday supervision through active streets. Aging
            in place as a feature, not an afterthought.
          </p>
        </li>
        <li>
          <div class="h-px w-10 bg-copper-400" aria-hidden="true"></div>
          <p class="eyebrow mt-4">05 / Daily Life</p>
          <p class="prose-body mt-3">
            Morning: coffee, bakery, produce. Midday: lunch and casual
            meetings. Afternoon: families, workshops. Evening: dinner,
            drinks, music. A habitual place. A routine, not just a
            weekend destination.
          </p>
        </li>
      </ol>
    </div>
  </section>

  {/* ============================================================ */}
  {/* SECTION 4 — AN ECOSYSTEM OF CARE                             */}
  {/* ============================================================ */}
  <section class="py-section">
    <div class="container-wide">
      <div class="max-w-3xl">
        <h2 class="font-display text-display-lg text-forest-700">
          An Ecosystem of Care.
        </h2>
        <p class="lede mt-6">
          Places designed for the way people actually live. At every
          age, every stage.
        </p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        <article class="rounded-2xl bg-cream-50 p-8 ring-1 ring-stone-100">
          <div class="flex h-16 items-end" aria-hidden="true">
            <svg viewBox="0 0 64 48" class="h-14 w-auto text-copper-400" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              {/* child */}
              <circle cx="14" cy="22" r="3" />
              <path d="M11 26 v12 M17 26 v12" />
              {/* adult */}
              <circle cx="32" cy="14" r="4.5" />
              <path d="M27 20 v20 M37 20 v20" />
              {/* elder with cane */}
              <circle cx="50" cy="18" r="3.5" />
              <path d="M47 22 v18 M53 22 v18 M55 24 v16" />
            </svg>
          </div>
          <h3 class="mt-6 font-display text-2xl text-forest-700">
            All Ages
          </h3>
          <p class="prose-body mt-4">
            Lifelong housing, mobility independence, and safety designed
            for kids, elders, and everyone in between.
          </p>
        </article>

        <article class="rounded-2xl bg-cream-50 p-8 ring-1 ring-stone-100">
          <div class="flex h-16 items-end" aria-hidden="true">
            <svg viewBox="0 0 64 48" class="h-14 w-auto text-copper-400" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="14" cy="18" r="3.5" />
              <path d="M11 22 v14 M17 22 v14" />
              <circle cx="32" cy="14" r="5" />
              <path d="M27 19 v22 M37 19 v22" />
              <circle cx="50" cy="18" r="3.5" />
              <path d="M47 22 v14 M53 22 v14" />
            </svg>
          </div>
          <h3 class="mt-6 font-display text-2xl text-forest-700">
            Children &amp; Families
          </h3>
          <p class="prose-body mt-4">
            Child-centered public realms, active streets for everyday
            supervision, and nature-based play.
          </p>
        </article>

        <article class="rounded-2xl bg-cream-50 p-8 ring-1 ring-stone-100">
          <div class="flex h-16 items-end" aria-hidden="true">
            <svg viewBox="0 0 64 48" class="h-14 w-auto text-copper-400" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="14" cy="16" r="4" />
              <circle cx="26" cy="14" r="4" />
              <circle cx="38" cy="14" r="4" />
              <circle cx="50" cy="16" r="4" />
              <path d="M9 22 v18 M19 22 v18 M21 22 v18 M31 22 v18 M33 22 v18 M43 22 v18 M45 22 v18 M55 22 v18" />
            </svg>
          </div>
          <h3 class="mt-6 font-display text-2xl text-forest-700">
            The Whole Community
          </h3>
          <p class="prose-body mt-4">
            Designing for the core creates an intergenerational community
            fabric that reduces isolation, increases stability, and
            outperforms conventional development on long-term value.
          </p>
        </article>
      </div>
    </div>
  </section>

  {/* ============================================================ */}
  {/* SECTION 5 — HOME AS SANCTUARY                                */}
  {/* ============================================================ */}
  <section class="py-section bg-cream-50">
    <div class="container-wide">
      <div class="grid gap-4 md:grid-cols-2 md:gap-6">
        <div class="overflow-hidden rounded-md shadow-sm">
          <Image
            src={section5Bedroom}
            alt="A serene Nordic bedroom with timber ceilings, linen bedding, and natural light."
            widths={[500, 800, 1200]}
            sizes="(min-width: 768px) 45vw, 100vw"
            class="h-auto w-full object-cover"
          />
        </div>
        <div class="overflow-hidden rounded-md shadow-sm">
          <Image
            src={section5Dining}
            alt="A bright dining and kitchen area with wooden table, pendant lighting, and large windows."
            widths={[500, 800, 1200]}
            sizes="(min-width: 768px) 45vw, 100vw"
            class="h-auto w-full object-cover"
          />
        </div>
      </div>
      <div class="mx-auto mt-12 max-w-3xl text-center">
        <h2 class="font-display text-display-lg text-forest-700">
          Home as Sanctuary.
        </h2>
        <p class="prose-body mt-6">
          Light-filled homes blending natural materials and Nordic
          simplicity with high-performance building systems. These
          environments are engineered to improve comfort, reduce energy
          costs, and support everyday wellness.
        </p>
      </div>
    </div>
  </section>

  {/* ============================================================ */}
  {/* SECTION 6 — THE PACIFIC NORTHWEST                            */}
  {/* ============================================================ */}
  <section class="py-section">
    <div class="container-wide">
      <div class="grid gap-12 md:grid-cols-2 md:items-center md:gap-16">
        <div>
          <h2 class="font-display text-display-lg text-forest-700">
            The Pacific Northwest.
          </h2>
          <p class="prose-body mt-8">
            A rare window where land use, policy, and market momentum
            align. Water is still abundant. Summers are still livable.
            The green is real.
          </p>
          <p class="prose-body mt-5">
            Our first neighborhood is somewhere in Oregon most people
            wouldn't guess. First homes by 2029.
          </p>
          <p class="prose-body mt-5">
            In the meantime, tell us where <em>you'd</em> want a Now City
            neighborhood. If enough of you say the same place, we pay
            attention.
          </p>
        </div>
        <div class="overflow-hidden rounded-md shadow-sm">
          <Image
            src={section6Landscape}
            alt="A Pacific Northwest river valley at dusk, with mountains in the distance and a green-roofed terrace in the foreground."
            widths={[600, 900, 1400]}
            sizes="(min-width: 768px) 50vw, 100vw"
            class="h-auto w-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  {/* ============================================================ */}
  {/* SECTION 7 — FOLLOW ALONG                                     */}
  {/* ============================================================ */}
  <section id="follow-along" class="py-section bg-cream-50">
    <div class="container-narrow">
      <div class="rounded-2xl bg-cream p-8 shadow-sm ring-1 ring-stone-100 md:p-12">
        <h2 class="font-display text-display-md text-forest-700">
          Follow along.
        </h2>
        <p class="prose-body mt-5">
          Tell us who you are and where you'd want this. We'll keep you
          in the loop.
        </p>

        {/*
          Mailchimp embedded-form endpoint for the "Now City Neighborhoods"
          audience (us19). Field/group IDs come straight from Mailchimp's
          embed code as of 2026-04-26.
        */}
        <form
          action="https://nowcitylabs.us19.list-manage.com/subscribe/post?u=88bfb2c8f34fdd20e85cce03f&amp;id=5812d18a23&amp;f_id=0099bbe7f0"
          method="post"
          target="_blank"
          novalidate
          class="mt-8 grid gap-5"
        >
          <div>
            <label for="EMAIL" class="block text-sm font-medium text-forest-800">
              Email <span class="text-copper-400">*</span>
            </label>
            <input
              id="EMAIL"
              name="EMAIL"
              type="email"
              required
              autocomplete="email"
              class="mt-2 w-full rounded-md border border-stone-200 bg-white px-4 py-3 text-base text-forest-800 placeholder:text-stone-400 focus:border-forest-700 focus:outline-none focus:ring-2 focus:ring-forest-700/20"
            />
          </div>

          <div>
            <label for="FNAME" class="block text-sm font-medium text-forest-800">
              First name <span class="text-copper-400">*</span>
            </label>
            <input
              id="FNAME"
              name="FNAME"
              type="text"
              required
              autocomplete="given-name"
              class="mt-2 w-full rounded-md border border-stone-200 bg-white px-4 py-3 text-base text-forest-800 placeholder:text-stone-400 focus:border-forest-700 focus:outline-none focus:ring-2 focus:ring-forest-700/20"
            />
          </div>

          <div>
            <label for="LOCATION" class="block text-sm font-medium text-forest-800">
              Where would you want a Now City neighborhood?
            </label>
            <input
              id="LOCATION"
              name="LOCATION"
              type="text"
              placeholder="city, metro, or ZIP"
              class="mt-2 w-full rounded-md border border-stone-200 bg-white px-4 py-3 text-base text-forest-800 placeholder:text-stone-400 focus:border-forest-700 focus:outline-none focus:ring-2 focus:ring-forest-700/20"
            />
          </div>

          <fieldset>
            <legend class="block text-sm font-medium text-forest-800">
              What brought you here?
            </legend>
            <div class="mt-3 grid gap-2 sm:grid-cols-2">
              <label class="flex cursor-pointer items-center gap-2 rounded-md border border-stone-200 bg-white px-4 py-3 text-sm text-forest-800 hover:border-forest-700/40 has-[:checked]:border-forest-700 has-[:checked]:bg-forest-700/5">
                <input type="radio" name="group[181120]" value="4" class="accent-forest-700" />
                Future resident
              </label>
              <label class="flex cursor-pointer items-center gap-2 rounded-md border border-stone-200 bg-white px-4 py-3 text-sm text-forest-800 hover:border-forest-700/40 has-[:checked]:border-forest-700 has-[:checked]:bg-forest-700/5">
                <input type="radio" name="group[181120]" value="8" class="accent-forest-700" />
                Landowner or operator
              </label>
              <label class="flex cursor-pointer items-center gap-2 rounded-md border border-stone-200 bg-white px-4 py-3 text-sm text-forest-800 hover:border-forest-700/40 has-[:checked]:border-forest-700 has-[:checked]:bg-forest-700/5">
                <input type="radio" name="group[181120]" value="16" class="accent-forest-700" />
                Investor
              </label>
              <label class="flex cursor-pointer items-center gap-2 rounded-md border border-stone-200 bg-white px-4 py-3 text-sm text-forest-800 hover:border-forest-700/40 has-[:checked]:border-forest-700 has-[:checked]:bg-forest-700/5">
                <input type="radio" name="group[181120]" value="32" class="accent-forest-700" />
                Curious
              </label>
            </div>
          </fieldset>

          {/*
            Housing interest. Mapped to Mailchimp Group 181121.
            Each checkbox name uses Mailchimp's group[GROUP_ID][OPTION_ID]
            convention. The value attribute is intentionally empty;
            checked-state alone tells Mailchimp to add the contact to
            that subgroup.
          */}
          <fieldset>
            <legend class="block text-sm font-medium text-forest-800">
              If a home opened up, what would catch your eye?
            </legend>
            <p class="mt-1 text-xs text-stone-500">Optional. Pick anything that fits.</p>
            <div class="mt-3 grid gap-2 sm:grid-cols-2">
              <label class="flex cursor-pointer items-center gap-2 rounded-md border border-stone-200 bg-white px-4 py-3 text-sm text-forest-800 hover:border-forest-700/40 has-[:checked]:border-forest-700 has-[:checked]:bg-forest-700/5">
                <input type="checkbox" name="group[181121][64]" class="accent-forest-700" />
                An apartment to rent
              </label>
              <label class="flex cursor-pointer items-center gap-2 rounded-md border border-stone-200 bg-white px-4 py-3 text-sm text-forest-800 hover:border-forest-700/40 has-[:checked]:border-forest-700 has-[:checked]:bg-forest-700/5">
                <input type="checkbox" name="group[181121][128]" class="accent-forest-700" />
                A loft to rent
              </label>
              <label class="flex cursor-pointer items-center gap-2 rounded-md border border-stone-200 bg-white px-4 py-3 text-sm text-forest-800 hover:border-forest-700/40 has-[:checked]:border-forest-700 has-[:checked]:bg-forest-700/5">
                <input type="checkbox" name="group[181121][256]" class="accent-forest-700" />
                A penthouse to rent
              </label>
              <label class="flex cursor-pointer items-center gap-2 rounded-md border border-stone-200 bg-white px-4 py-3 text-sm text-forest-800 hover:border-forest-700/40 has-[:checked]:border-forest-700 has-[:checked]:bg-forest-700/5">
                <input type="checkbox" name="group[181121][512]" class="accent-forest-700" />
                A condo to own
              </label>
              <label class="flex cursor-pointer items-center gap-2 rounded-md border border-stone-200 bg-white px-4 py-3 text-sm text-forest-800 hover:border-forest-700/40 has-[:checked]:border-forest-700 has-[:checked]:bg-forest-700/5">
                <input type="checkbox" name="group[181121][1024]" class="accent-forest-700" />
                A townhome to own
              </label>
              <label class="flex cursor-pointer items-center gap-2 rounded-md border border-stone-200 bg-white px-4 py-3 text-sm text-forest-800 hover:border-forest-700/40 has-[:checked]:border-forest-700 has-[:checked]:bg-forest-700/5">
                <input type="checkbox" name="group[181121][2048]" class="accent-forest-700" />
                Curious about all of it
              </label>
            </div>
          </fieldset>

          {/* Mailchimp anti-bot honeypot. Hidden field; bots fill it, humans don't. */}
          <div style="position:absolute;left:-5000px" aria-hidden="true">
            <input type="text" name="b_88bfb2c8f34fdd20e85cce03f_5812d18a23" tabindex="-1" value="" />
          </div>

          <div class="mt-2">
            <button type="submit" class="btn-primary">
              Follow along
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>

  {/* ============================================================ */}
  {/* SECTION 8 — CLOSING                                          */}
  {/* ============================================================ */}
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <Image
        src={section8Sunset}
        alt=""
        widths={[1200, 1800, 2200]}
        sizes="100vw"
        class="h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-cream/60"></div>
    </div>
    <div class="container-narrow py-section text-center">
      <h2 class="font-display text-display-lg text-forest-700">
        Building places people truly care about.
      </h2>
      <p class="mt-8 text-sm text-stone-600">
        A project of <strong class="font-semibold text-forest-800">Now City Inc.</strong>, a small,
        bootstrapped team building for the long now.
      </p>
      <p class="mt-4 text-sm text-stone-600">
        For developers, landowners, and municipalities →
        <a href="https://nowcitylabs.com" class="text-forest-700 underline">nowcitylabs.com</a>
      </p>
    </div>
  </section>

  {/* ============================================================ */}
  {/* FOOTER                                                       */}
  {/* ============================================================ */}
  <footer class="border-t border-stone-100 py-10">
    <div class="container-wide flex flex-col items-start justify-between gap-4 text-xs text-stone-500 md:flex-row md:items-center">
      <p>© {new Date().getFullYear()} Now City Inc. All rights reserved.</p>
      <p>
        For developers, landowners, and municipalities →
        <a href="https://nowcitylabs.com" class="text-forest-700 underline">nowcitylabs.com</a>
      </p>
    </div>
  </footer>
</Layout>

